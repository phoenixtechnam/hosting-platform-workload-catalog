{
  "name": "MariaDB 11.4",
  "code": "mariadb-114",
  "type": "database",
  "version": "11.4",
  "description": "MariaDB 11.4 LTS — current long-term support release",
  "image": "mariadb:11.4",
  "has_dockerfile": false,
  "min_plan": "starter",
  "runtime": "mariadb",
  "web_server": null,
  "deployment_strategy": "statefulset",
  "resources": {
    "cpu": "0.25",
    "memory": "256Mi",
    "storage": "5Gi"
  },
  "health_check": {
    "path": null,
    "command": [
      "healthcheck.sh",
      "--connect",
      "--innodb_initialized"
    ],
    "port": null,
    "initial_delay_seconds": 60,
    "period_seconds": 30
  },
  "tags": [
    "database",
    "mariadb",
    "mysql-compatible",
    "sql",
    "lts"
  ],
  "exposes": {
    "ports": [
      {
        "port": 3306,
        "protocol": "mysql",
        "name": "database",
        "publishable": false
      }
    ],
    "volumes": [
      {
        "description": "Database data",
        "local_path": "db/mariadb",
        "container_path": "/var/lib/mysql"
      }
    ],
    "env_vars": {
      "configurable": [
        "MARIADB_DATABASE",
        "MARIADB_USER"
      ],
      "generated": [
        "MARIADB_ROOT_PASSWORD",
        "MARIADB_PASSWORD"
      ],
      "fixed": {
        "MARIADB_AUTO_UPGRADE": "1"
      }
    },
    "services": {
      "database": {
        "engine": "mariadb",
        "version": "11.4",
        "protocol": "mysql"
      }
    }
  }
}
