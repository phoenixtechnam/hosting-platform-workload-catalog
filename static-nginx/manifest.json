{
  "name": "Static Website (via NGINX)",
  "code": "static-nginx",
  "type": "runtime",
  "version": "1.27",
  "description": "NGINX serving static HTML/CSS/JS sites",
  "image": null,
  "has_dockerfile": true,
  "min_plan": "starter",
  "runtime": "static",
  "web_server": "nginx",
  "deployment_strategy": "deployment",
  "resources": {
    "cpu": "0.10",
    "memory": "64Mi"
  },
  "health_check": {
    "path": "/health",
    "command": null,
    "port": 80,
    "initial_delay_seconds": 10,
    "period_seconds": 30
  },
  "services": {},
  "tags": [
    "static",
    "nginx",
    "html"
  ],
  "exposes": {
    "ports": [
      {
        "port": 80,
        "protocol": "http",
        "name": "web",
        "publishable": true
      }
    ],
    "volumes": [
      {
        "description": "Static files",
        "local_path": "web",
        "container_path": "/var/www/html"
      }
    ],
    "env_vars": {
      "configurable": [],
      "fixed": {}
    }
  }
}
