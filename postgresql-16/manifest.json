{
  "name": "PostgreSQL 16",
  "code": "postgresql-16",
  "type": "database",
  "version": "16",
  "description": "PostgreSQL 16 — dedicated instance for client databases",
  "image": "postgres:16-alpine",
  "has_dockerfile": false,
  "min_plan": "business",
  "runtime": "postgresql",
  "web_server": null,
  "deployment_strategy": "statefulset",
  "resources": {
    "cpu": "0.25",
    "memory": "256Mi",
    "storage": "5Gi"
  },
  "health_check": {
    "path": null,
    "command": [
      "pg_isready",
      "-U",
      "postgres"
    ],
    "port": null,
    "initial_delay_seconds": 30,
    "period_seconds": 30
  },
  "tags": [
    "database",
    "postgresql",
    "sql"
  ],
  "exposes": {
    "ports": [
      {
        "port": 5432,
        "protocol": "postgresql",
        "name": "database",
        "publishable": false
      }
    ],
    "volumes": [
      {
        "description": "Database data",
        "local_path": "db/postgresql",
        "container_path": "/var/lib/postgresql/data"
      }
    ],
    "env_vars": {
      "configurable": [
        "POSTGRES_DB",
        "POSTGRES_USER"
      ],
      "generated": [
        "POSTGRES_PASSWORD"
      ],
      "fixed": {}
    },
    "services": {
      "database": {
        "engine": "postgresql",
        "version": "16",
        "protocol": "postgresql"
      }
    }
  }
}
