{
  "name": "Memcached",
  "code": "memcached-alpine",
  "type": "service",
  "version": "1.6",
  "description": "Memcached in-memory cache — lightweight alternative to Redis for simple key-value caching",
  "image": "memcached:1.6-alpine",
  "has_dockerfile": false,
  "min_plan": "starter",
  "runtime": "memcached",
  "web_server": null,
  "deployment_strategy": "deployment",
  "resources": {
    "cpu": "0.10",
    "memory": "128Mi"
  },
  "health_check": {
    "path": null,
    "command": [
      "sh",
      "-c",
      "echo stats | nc localhost 11211 | grep -q pid"
    ],
    "port": null,
    "initial_delay_seconds": 10,
    "period_seconds": 30
  },
  "tags": [
    "cache",
    "memcached",
    "key-value"
  ],
  "exposes": {
    "ports": [
      {
        "port": 11211,
        "protocol": "memcached",
        "name": "cache",
        "publishable": false
      }
    ],
    "volumes": [],
    "env_vars": {
      "configurable": [
        "MEMCACHED_MAX_MEMORY"
      ],
      "fixed": {}
    }
  }
}
