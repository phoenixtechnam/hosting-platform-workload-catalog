{
  "name": "Node.js 20 LTS",
  "code": "node20-lts",
  "type": "runtime",
  "version": "20",
  "description": "Node.js 20 LTS runtime for server-side JavaScript applications",
  "image": null,
  "has_dockerfile": true,
  "min_plan": "starter",
  "runtime": "node",
  "web_server": "pm2",
  "deployment_strategy": "deployment",
  "resources": {
    "cpu": "0.25",
    "memory": "256Mi"
  },
  "health_check": {
    "path": "/health",
    "command": null,
    "port": 3000,
    "initial_delay_seconds": 30,
    "period_seconds": 30
  },
  "services": {
    "database": {
      "required": false,
      "engines": [
        {
          "type": "mariadb",
          "min_version": "10.4"
        },
        {
          "type": "mysql",
          "min_version": "5.7"
        },
        {
          "type": "postgresql",
          "min_version": "12"
        }
      ],
      "env_mapping": {
        "url": "DATABASE_URL"
      }
    }
  },
  "tags": [
    "nodejs",
    "javascript",
    "runtime",
    "lts"
  ],
  "exposes": {
    "ports": [
      {
        "port": 3000,
        "protocol": "http",
        "name": "app",
        "publishable": true
      }
    ],
    "volumes": [
      {
        "description": "Application directory",
        "local_path": "app/node",
        "container_path": "/app"
      }
    ],
    "env_vars": {
      "configurable": [
        "NODE_ENV",
        "DATABASE_URL"
      ],
      "fixed": {
        "PORT": "3000"
      }
    }
  }
}
