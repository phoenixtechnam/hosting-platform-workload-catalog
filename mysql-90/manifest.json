{
  "name": "MySQL 9.0",
  "code": "mysql-90",
  "type": "database",
  "version": "9.0",
  "description": "MySQL 9.0 Innovation release — for clients who specifically need MySQL over MariaDB",
  "image": "mysql:9.0",
  "has_dockerfile": false,
  "min_plan": "starter",
  "runtime": "mysql",
  "web_server": null,
  "deployment_strategy": "statefulset",
  "resources": {
    "cpu": "0.25",
    "memory": "512Mi",
    "storage": "5Gi"
  },
  "health_check": {
    "path": null,
    "command": [
      "mysqladmin",
      "ping",
      "-h",
      "localhost"
    ],
    "port": null,
    "initial_delay_seconds": 60,
    "period_seconds": 30
  },
  "tags": [
    "database",
    "mysql",
    "sql"
  ],
  "exposes": {
    "ports": [
      {
        "port": 3306,
        "protocol": "mysql",
        "name": "database",
        "publishable": false
      }
    ],
    "volumes": [
      {
        "description": "Database data",
        "local_path": "db/mariadb",
        "container_path": "/var/lib/mysql"
      }
    ],
    "env_vars": {
      "configurable": [
        "MYSQL_DATABASE",
        "MYSQL_USER"
      ],
      "generated": [
        "MYSQL_ROOT_PASSWORD",
        "MYSQL_PASSWORD"
      ],
      "fixed": {}
    },
    "services": {
      "database": {
        "engine": "mysql",
        "version": "9.0",
        "protocol": "mysql"
      }
    }
  }
}
