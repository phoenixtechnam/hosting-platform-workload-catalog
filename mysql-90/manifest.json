{
  "name": "MySQL 9.0",
  "code": "mysql-90",
  "type": "database",
  "version": "9.0",
  "description": "MySQL 9.0 Innovation release — for clients who specifically need MySQL over MariaDB",
  "image": "mysql:9.0",
  "has_dockerfile": false,
  "min_plan": "starter",
  "runtime": "mysql",
  "web_server": null,
  "deployment_strategy": "statefulset",
  "resources": {
    "cpu": "0.25",
    "memory": "512Mi",
    "storage": "5Gi"
  },
  "container_port": 3306,
  "mount_path": "/var/lib/mysql",
  "health_check": {
    "path": null,
    "command": ["mysqladmin", "ping", "-h", "localhost"],
    "port": null,
    "initial_delay_seconds": 60,
    "period_seconds": 30
  },
  "env_vars": {
    "configurable": [
      "MYSQL_ROOT_PASSWORD",
      "MYSQL_DATABASE",
      "MYSQL_USER",
      "MYSQL_PASSWORD"
    ],
    "fixed": {}
  },
  "provides": {
    "database": {
      "engine": "mysql",
      "version": "9.0",
      "protocol": "mysql",
      "port": 3306,
      "credentials": {
        "root_env": "MYSQL_ROOT_PASSWORD",
        "user_env": "MYSQL_USER",
        "password_env": "MYSQL_PASSWORD",
        "database_env": "MYSQL_DATABASE"
      }
    }
  },
  "tags": ["database", "mysql", "sql"],
  "volume_group": "db/mariadb"
}
