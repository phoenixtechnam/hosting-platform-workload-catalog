{
  "name": "Redis 7",
  "code": "redis-7",
  "type": "service",
  "version": "7",
  "description": "Redis 7 in-memory cache — dedicated instance",
  "image": "redis:7-alpine",
  "has_dockerfile": false,
  "min_plan": "business",
  "runtime": "redis",
  "web_server": null,
  "deployment_strategy": "statefulset",
  "resources": {
    "cpu": "0.10",
    "memory": "128Mi",
    "storage": "1Gi"
  },
  "health_check": {
    "path": null,
    "command": [
      "redis-cli",
      "ping"
    ],
    "port": null,
    "initial_delay_seconds": 10,
    "period_seconds": 30
  },
  "tags": [
    "cache",
    "redis",
    "key-value"
  ],
  "exposes": {
    "ports": [
      {
        "port": 6379,
        "protocol": "redis",
        "name": "cache",
        "publishable": false
      }
    ],
    "volumes": [
      {
        "description": "Cache data",
        "local_path": "cache/redis",
        "container_path": "/data"
      }
    ],
    "env_vars": {
      "configurable": [],
      "fixed": {}
    }
  }
}
