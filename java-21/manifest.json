{
  "name": "Java 21",
  "code": "java-21",
  "type": "runtime",
  "version": "21",
  "description": "Eclipse Temurin Java 21 runtime for Spring Boot and JVM applications",
  "image": null,
  "has_dockerfile": true,
  "min_plan": "starter",
  "runtime": "java",
  "web_server": "built-in",
  "deployment_strategy": "deployment",
  "resources": {
    "cpu": "0.50",
    "memory": "512Mi"
  },
  "health_check": {
    "path": "/actuator/health",
    "command": null,
    "port": 8080,
    "initial_delay_seconds": 60,
    "period_seconds": 30
  },
  "services": {
    "database": {
      "required": false,
      "engines": [
        {
          "type": "mariadb",
          "min_version": "10.4"
        },
        {
          "type": "mysql",
          "min_version": "5.7"
        },
        {
          "type": "postgresql",
          "min_version": "12"
        }
      ],
      "env_mapping": {
        "url": "DATABASE_URL"
      }
    }
  },
  "tags": [
    "java",
    "spring-boot",
    "jvm"
  ],
  "exposes": {
    "ports": [
      {
        "port": 8080,
        "protocol": "http",
        "name": "app",
        "publishable": true
      }
    ],
    "volumes": [
      {
        "description": "Application directory",
        "local_path": "app/java",
        "container_path": "/app"
      }
    ],
    "env_vars": {
      "configurable": [
        "SPRING_PROFILES_ACTIVE",
        "DATABASE_URL"
      ],
      "fixed": {
        "PORT": "8080"
      }
    }
  }
}
