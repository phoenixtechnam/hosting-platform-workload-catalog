{
  "name": "Bun (Latest)",
  "code": "bun-latest",
  "type": "runtime",
  "version": "latest",
  "description": "Bun runtime — fast JavaScript/TypeScript runtime, bundler, and package manager",
  "image": "oven/bun:latest",
  "has_dockerfile": true,
  "min_plan": "starter",
  "runtime": "bun",
  "web_server": "bun",
  "deployment_strategy": "deployment",
  "resources": {
    "cpu": "0.25",
    "memory": "256Mi"
  },
  "health_check": {
    "path": "/health",
    "command": null,
    "port": 3000,
    "initial_delay_seconds": 15,
    "period_seconds": 30
  },
  "services": {
    "database": {
      "required": false,
      "engines": [
        {
          "type": "postgresql",
          "min_version": "12"
        },
        {
          "type": "mariadb",
          "min_version": "10.4"
        }
      ],
      "env_mapping": {
        "url": "DATABASE_URL"
      }
    }
  },
  "tags": [
    "bun",
    "javascript",
    "typescript",
    "runtime"
  ],
  "exposes": {
    "ports": [
      {
        "port": 3000,
        "protocol": "http",
        "name": "app",
        "publishable": true
      }
    ],
    "volumes": [
      {
        "description": "Application directory",
        "local_path": "app/bun",
        "container_path": "/app"
      }
    ],
    "env_vars": {
      "configurable": [
        "NODE_ENV",
        "DATABASE_URL"
      ],
      "fixed": {
        "PORT": "3000"
      }
    }
  }
}
