{
  "name": "Bun (Latest)",
  "code": "bun-latest",
  "type": "runtime",
  "version": "latest",
  "description": "Bun runtime — fast JavaScript/TypeScript runtime, bundler, and package manager",
  "image": "oven/bun:latest",
  "has_dockerfile": true,
  "min_plan": "starter",
  "runtime": "bun",
  "web_server": "bun",
  "deployment_strategy": "deployment",
  "resources": {
    "cpu": "0.25",
    "memory": "256Mi"
  },
  "container_port": 3000,
  "mount_path": "/app",
  "health_check": {
    "path": "/health",
    "command": null,
    "port": 3000,
    "initial_delay_seconds": 15,
    "period_seconds": 30
  },
  "env_vars": {
    "configurable": [
      "NODE_ENV"
    ],
    "fixed": {
      "PORT": "3000"
    }
  },
  "services": {
    "database": {
      "required": false,
      "engines": [
        { "type": "postgresql", "min_version": "12" },
        { "type": "mariadb", "min_version": "10.4" }
      ],
      "env_mapping": { "url": "DATABASE_URL" }
    }
  },
  "tags": ["bun", "javascript", "typescript", "runtime"],
  "volume_group": "app/bun"
}
