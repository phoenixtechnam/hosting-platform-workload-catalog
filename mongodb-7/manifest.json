{
  "name": "MongoDB 7",
  "code": "mongodb-7",
  "type": "database",
  "version": "7",
  "description": "MongoDB 7 document database — dedicated instance for NoSQL applications",
  "image": "mongo:7",
  "has_dockerfile": false,
  "min_plan": "business",
  "runtime": "mongodb",
  "web_server": null,
  "deployment_strategy": "statefulset",
  "resources": {
    "cpu": "0.25",
    "memory": "512Mi",
    "storage": "10Gi"
  },
  "container_port": 27017,
  "mount_path": "/data/db",
  "health_check": {
    "path": null,
    "command": ["mongosh", "--eval", "db.adminCommand('ping')"],
    "port": null,
    "initial_delay_seconds": 30,
    "period_seconds": 30
  },
  "env_vars": {
    "configurable": ["MONGO_INITDB_ROOT_USERNAME", "MONGO_INITDB_ROOT_PASSWORD", "MONGO_INITDB_DATABASE"],
    "fixed": {}
  },
  "provides": {
    "database": {
      "engine": "mongodb",
      "version": "7",
      "protocol": "mongodb",
      "port": 27017,
      "credentials": {
        "root_env": "MONGO_INITDB_ROOT_USERNAME",
        "user_env": "MONGO_INITDB_ROOT_USERNAME",
        "password_env": "MONGO_INITDB_ROOT_PASSWORD",
        "database_env": "MONGO_INITDB_DATABASE"
      }
    }
  },
  "tags": ["database", "mongodb", "nosql", "document"]
}
