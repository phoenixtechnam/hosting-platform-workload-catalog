{
  "name": "MongoDB 7",
  "code": "mongodb-7",
  "type": "database",
  "version": "7",
  "description": "MongoDB 7 document database — dedicated instance for NoSQL applications",
  "image": "mongo:7",
  "has_dockerfile": false,
  "min_plan": "business",
  "runtime": "mongodb",
  "web_server": null,
  "deployment_strategy": "statefulset",
  "resources": {
    "cpu": "0.25",
    "memory": "512Mi",
    "storage": "10Gi"
  },
  "health_check": {
    "path": null,
    "command": [
      "mongosh",
      "--eval",
      "db.adminCommand('ping')"
    ],
    "port": null,
    "initial_delay_seconds": 30,
    "period_seconds": 30
  },
  "tags": [
    "database",
    "mongodb",
    "nosql",
    "document"
  ],
  "exposes": {
    "ports": [
      {
        "port": 27017,
        "protocol": "mongodb",
        "name": "database",
        "publishable": false
      }
    ],
    "volumes": [
      {
        "description": "Database data",
        "local_path": "db/mongodb",
        "container_path": "/data/db"
      }
    ],
    "env_vars": {
      "configurable": [
        "MONGO_INITDB_DATABASE"
      ],
      "generated": [
        "MONGO_INITDB_ROOT_USERNAME",
        "MONGO_INITDB_ROOT_PASSWORD"
      ],
      "fixed": {}
    },
    "services": {
      "database": {
        "engine": "mongodb",
        "version": "7",
        "protocol": "mongodb"
      }
    }
  }
}
